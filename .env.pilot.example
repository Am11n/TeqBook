# TeqBook pilot-production environment template (safe to commit).
#
# Your real values live in `.env.pilot` (gitignored). Each Next app reads only its own `.env.local`:
#   `apps/dashboard/.env.local` — staff flows, test email, reschedule notifications, …
#   `apps/public/.env.local` — customer booking confirmation (POST /api/bookings/send-notifications)
# Sync Resend into both, e.g.:
#   grep -E '^(RESEND_API_KEY|EMAIL_[A-Z_]+)=' .env.pilot >> apps/dashboard/.env.local
#   grep -E '^(RESEND_API_KEY|EMAIL_[A-Z_]+)=' .env.pilot >> apps/public/.env.local
# Vercel: set the same keys on **both** the dashboard and the public Vercel projects, then redeploy.
# See docs/ops/pilot-resend-integration.md
TEQBOOK_ENV_TARGET=pilot-production
TEQBOOK_STAGING_PROJECT_REF=
TEQBOOK_PILOT_PROJECT_REF=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://teqbook.com
# Customer links (reschedule approval, etc.): URL of the deployed public app. Falls back to NEXT_PUBLIC_APP_URL if unset.
# NEXT_PUBLIC_PUBLIC_APP_URL=https://teqbook.com

SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- Transactional email (dashboard + public on Vercel): Resend API ---
# Create key at https://resend.com/api-keys ; domain must be verified in Resend for EMAIL_FROM.
RESEND_API_KEY=
EMAIL_FROM=no-reply@teqbook.com
EMAIL_FROM_NAME=TeqBook
# Optional: EMAIL_REPLY_TO=, EMAIL_UNSUBSCRIBE=

# Auth email (password reset, magic link) is configured in Supabase Dashboard → Authentication → SMTP,
# not via these vars. Use Resend SMTP (e.g. smtp.resend.com:465, user "resend", SMTP password from Resend).

