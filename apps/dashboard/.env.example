# Comma-separated dashboard locales that must match English keys in parity tests (default in code: en,nb).
# Use all 15 for full coverage in CI: en,nb,ar,so,ti,am,tr,pl,vi,zh,tl,fa,dar,ur,hi
# NEXT_PUBLIC_DASHBOARD_LOCALE_ALLOWLIST=en,nb

# Base URL of the Admin app (Next on port 3003 locally). Superadmin users are redirected here from the dashboard.
# NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3003
