# Comma-separated dashboard locales that must match English keys in parity tests (default in code: en,nb).
# Use all 15 for full coverage in CI: en,nb,ar,so,ti,am,tr,pl,vi,zh,tl,fa,dar,ur,hi
# NEXT_PUBLIC_DASHBOARD_LOCALE_ALLOWLIST=en,nb

# Base URL of the Admin app (Next on port 3003 locally). Superadmin users are redirected here from the dashboard.
# NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3003

# Machine translation: `pnpm run i18n:machine-translate` (all MT locales incl. ar) or `pnpm run i18n:machine-translate:skip-ar`
# Auto-pick order: GROQ_API_KEY → OPENAI_API_KEY → OLLAMA_MT_MODEL (local) → LibreTranslate. Override with MT_ENGINE=groq|openai|ollama|libretranslate
#
# Local LLM — no cloud API; runs on your machine (https://ollama.com). Use MT_ENGINE=ollama if you also have GROQ_API_KEY but want local only.
# OLLAMA_MT_MODEL=llama3.2
# OLLAMA_HOST=http://127.0.0.1:11434
#
# Groq (free tier, no credit card): https://console.groq.com
# GROQ_API_KEY=
# GROQ_MT_MODEL=llama-3.3-70b-versatile
# Smaller/cheaper on TPD: llama-3.1-8b-instant
# GROQ_API_BASE=https://api.groq.com/openai/v1
#
# OpenAI (optional fallback when Groq hits daily/rate limits — set alongside GROQ_API_KEY)
# OPENAI_API_KEY=
# OPENAI_MT_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1
# MT_OPENAI_FALLBACK_ON_GROQ_LIMIT=0   # set to 0 to disable OpenAI fallback
#
# LibreTranslate (subset of locales; Somali/Tigrinya/Amharic need LLM above). Cloud needs key: https://portal.libretranslate.com
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=
# Or self-host: LIBRETRANSLATE_URL=http://127.0.0.1:5000
#
# MT_DELAY_MS=400
