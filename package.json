{
  "name": "teqbook",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:public": "npm run build --workspace=@teqbook/public",
    "build:dashboard": "npm run build --workspace=@teqbook/dashboard",
    "build:admin": "npm run build --workspace=@teqbook/admin",
    "dev": "pnpm --parallel run dev",
    "dev:public": "npm run dev --workspace=@teqbook/public",
    "dev:dashboard": "npm run dev --workspace=@teqbook/dashboard",
    "dev:admin": "npm run dev --workspace=@teqbook/admin",
    "start:public": "npm run start --workspace=@teqbook/public",
    "start:dashboard": "npm run start --workspace=@teqbook/dashboard",
    "start:admin": "npm run start --workspace=@teqbook/admin",
    "type-check": "npm run type-check --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:run": "pnpm --filter '@teqbook/dashboard' run test:run && pnpm --filter '@teqbook/public' run test:run && pnpm --filter '@teqbook/admin' run test:run",
    "test:coverage": "pnpm --filter '@teqbook/dashboard' run test:coverage",
    "test:coverage:public": "pnpm --filter '@teqbook/public' run test:coverage",
    "test:coverage:admin": "pnpm --filter '@teqbook/admin' run test:coverage",
    "test:e2e": "playwright test",
    "test:integration": "pnpm --filter '@teqbook/dashboard' run test:integration",
    "test:load:public": "k6 run tests/load/public-booking-smoke.js",
    "test:load:dashboard": "k6 run tests/load/dashboard-api-smoke.js",
    "test:load:staging": "pnpm run test:load:public && pnpm run test:load:dashboard",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:critical": "playwright test --grep @critical",
    "seed": "tsx scripts/seed.ts",
    "seed:reset": "tsx scripts/seed.ts --reset",
    "seed:force": "tsx scripts/seed.ts --force",
    "db:manifest:verify": "tsx scripts/db-manifest.ts verify",
    "db:manifest:lock": "tsx scripts/db-manifest.ts lock",
    "db:apply": "tsx scripts/db-apply.ts",
    "db:verify": "tsx scripts/db-verify.ts",
    "create:e2e-users": "tsx scripts/create-e2e-users.ts",
    "create:e2e-users:cleanup": "tsx scripts/create-e2e-users.ts --cleanup",
    "setup:e2e": "pnpm run create:e2e-users",
    "setup:e2e:clean": "pnpm run create:e2e-users -- --cleanup",
    "migrate:local": "tsx scripts/migrate-local.ts",
    "reset:db": "tsx scripts/reset-db.ts",
    "check:file-length": "tsx scripts/check-file-length.ts",
    "check:file-length:ci": "tsx scripts/check-file-length.ts --ci",
    "check:bundle-size": "tsx scripts/check-bundle-size.ts",
    "check:api-latency": "tsx scripts/check-api-latency.ts",
    "check:query-budgets": "tsx scripts/check-query-budgets.ts",
    "format:check": "tsx scripts/check-format-ratchet.ts --ci",
    "format": "npm run format --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.7",
    "glob": "^11.0.0",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "5.0.1",
      "minimatch": "10.2.3",
      "rollup": "4.59.0",
      "serialize-javascript": "7.0.3"
    }
  }
}
